# ============ Vertex AI / Gemini ============
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
VERTEX_MODEL=gemini-2.5-pro
VERTEX_EMBED_MODEL=text-embedding-004

# ============ Pinecone ============
PINECONE_API_KEY=
PINECONE_INDEX=ub-cse-chatbot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=768

# ============ Neo4j ============
# Aura format: neo4j+s://<id>.databases.neo4j.io
# Local format: bolt://localhost:7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# Set to false to disable runtime KG queries (server still starts).
ENABLE_KG_RUNTIME=true

# ============ Crawler ============
CRAWL_ROOT=https://engineering.buffalo.edu/computer-science-engineering.html
CRAWL_ALLOWED_DOMAINS=engineering.buffalo.edu,buffalo.edu
CRAWL_MAX_DEPTH=4
CRAWL_MAX_PAGES=1500
CRAWL_CONCURRENCY=8

# ============ Rerank ============
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TOP_K=8

# ============ App ============
APP_LOG_LEVEL=INFO
ENABLE_PERSONAL_MEMORY=false
MEMORY_STORE_PATH=./data/memory
